# ============================================================
# GOALZONE — Environment Variables Template
# ============================================================
# Salin file ini menjadi .env.local untuk development
# Di Vercel, set setiap variabel via Dashboard → Settings → Environment Variables
# ============================================================

# ─── SITE URL (WAJIB) ─────────────────────────────────────────
# Ganti dengan domain production kamu
NEXT_PUBLIC_SITE_URL=https://goalzone.vercel.app
SITE_URL=https://goalzone.vercel.app

# ─── ADMIN AUTH (WAJIB) ──────────────────────────────────────
# ⚠️ GANTI password sebelum deploy ke production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GANTI_INI_DENGAN_PASSWORD_YANG_KUAT
JWT_SECRET=GANTI_INI_DENGAN_STRING_RANDOM_MIN_32_KARAKTER

# ─── NEXT-AUTH (Opsional, jika pakai OAuth) ───────────────────
NEXTAUTH_URL=https://goalzone.vercel.app
NEXTAUTH_SECRET=GANTI_INI_DENGAN_STRING_RANDOM_MIN_32_KARAKTER

# ─── ADMIN API KEY (Opsional) ────────────────────────────────
ADMIN_API_KEY=GANTI_INI_DENGAN_STRING_RANDOM

# ─── SUPABASE (WAJIB — untuk data match_results) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# ⚠️ NEXT_PUBLIC_SUPABASE_ANON_KEY DIHAPUS demi keamanan.
# Semua akses Supabase sekarang melalui API routes (server-side only).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── API-FOOTBALL v3 (Opsional, untuk live scores) ─────────────
# ⚠️ NEXT_PUBLIC_FOOTBALL_API_KEY DIHAPUS demi keamanan.
# Football API hanya diakses dari server-side API routes.
FOOTBALL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── REVALIDATION (Opsional, untuk ISR on-demand) ─────────────
REVALIDATION_SECRET=GANTI_INI_DENGAN_STRING_RANDOM

# ─── ARTICLE GENERATOR (Opsional) ─────────────────────────────
ARTICLE_GEN_AUTHOR_ID=
ARTICLE_GEN_CATEGORY_ID=

# ─── GOOGLE SEO (Opsional) ────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
GOOGLE_SITE_VERIFICATION=

# ─── CRON SECRETS (Opsional) ──────────────────────────────────
CRON_SECRET=GANTI_INI_DENGAN_STRING_RANDOM

# ─── DATABASE (LOCAL ONLY — tidak perlu di Vercel) ────────────
# DATABASE_URL=file:./db/custom.db
