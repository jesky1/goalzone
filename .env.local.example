# ============================================================
# GOALZONE — Environment Variables
# ============================================================
# Salin file ini menjadi .env.local dan isi semua value-nya
# ============================================================

# ─── SITE URL (penting untuk SEO & sitemap) ──────────────────
# Ganti dengan domain kamu yang sudah online
NEXT_PUBLIC_SITE_URL=https://goalzone.vercel.app
SITE_URL=https://goalzone.vercel.app

# ─── NEXT-AUTH ───────────────────────────────────────────────
NEXTAUTH_URL=https://goalzone.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-here

# ─── ADMIN AUTH ──────────────────────────────────────────────
# ⚠️ WAJIB diisi — tanpa ini login admin tidak akan berfungsi
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password-here
JWT_SECRET=your-jwt-secret-key-at-least-32-chars
ADMIN_API_KEY=your-admin-api-key-here

# ─── DATABASE (SQLite local) ─────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ─── SUPABASE ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── API-FOOTBALL (v3) ──────────────────────────────────────
FOOTBALL_API_KEY=your-api-football-key
NEXT_PUBLIC_FOOTBALL_API_KEY=your-api-football-key

# ─── REVALIDATION ────────────────────────────────────────────
REVALIDATION_SECRET=your-revalidation-secret

# ─── ARTICLE GENERATOR ───────────────────────────────────────
ARTICLE_GEN_AUTHOR_ID=
ARTICLE_GEN_CATEGORY_ID=
ARTICLE_GEN_PORT=3005

# ─── GOOGLE SEO ──────────────────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Search Console verification code
GOOGLE_SITE_VERIFICATION=

# ─── CRON SECRETS (untuk production) ─────────────────────────
# Jika pakai Vercel Cron Jobs, isi ini:
CRON_SECRET=your-cron-secret
